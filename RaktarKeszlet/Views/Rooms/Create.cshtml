@model RaktarKeszlet.Models.Room

@{
    ViewData["Title"] = "Új helyiség felvitele";
}

<h1>Új helyiség rögzítése</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" class="bg-light p-4 rounded shadow-sm border">
            <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

            <div class="mb-3">
                <label asp-for="BuildingId" class="form-label fw-bold">Melyik épületben található?</label>
                <select asp-for="BuildingId" class="form-select form-select-lg" asp-items="ViewBag.BuildingId">
                    <option value="">-- Válassz épületet! --</option>
                </select>
                <span asp-validation-for="BuildingId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Helyiség neve</label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="Pl. 1. raktár, Hűtőkamra" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg">Mentés</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">Vissza a listához</a>
            </div>
        </form>
    </div>
</div>