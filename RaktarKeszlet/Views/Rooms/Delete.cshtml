@model RaktarKeszlet.Models.Room

@{
    ViewData["Title"] = "Helyiség törlése";
}

<h1 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Törlés jóváhagyása</h1>
<h3>Biztosan törölni szeretnéd ezt a helyiséget?</h3>
<p class="text-muted">A művelet végleges és nem vonható vissza!</p>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Törlendő helyiség adatai</h5>
            </div>
            <div class="card-body bg-light">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Helyiség neve</dt>
                    <dd class="col-sm-7 fw-bold fs-4">@Model.Name</dd>

                    <dt class="col-sm-5 text-muted mt-3">Melyik épületben található?</dt>
                    <dd class="col-sm-7 mt-3">
                        @(Model.Building != null ? Model.Building.Name : "Nincs épülethez rendelve")
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-top-0 pt-3 pb-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Igen, véglegesen törlöm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Mégse, vissza</a>
                </form>
            </div>
        </div>
    </div>
</div>