@model RaktarKeszlet.Models.Room

@{
    ViewData["Title"] = "Helyiség részletei";
}

<h1>Helyiség részletei</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-door-open"></i> Alapadatok</h5>
            </div>
            <div class="card-body bg-light">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Helyiség neve</dt>
                    <dd class="col-sm-7 fw-bold fs-4">@Model.Name</dd>

                    <dt class="col-sm-5 text-muted mt-3">Melyik épületben található?</dt>
                    <dd class="col-sm-7 mt-3">
                        @if (Model.Building != null)
                        {
                            <span class="badge bg-primary fs-6">@Model.Building.Name</span>
                        }
                        else
                        {
                            <span class="text-danger">Nincs épülethez rendelve</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-top-0 pt-3 pb-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Szerkesztés</a>
                <a asp-action="Index" class="btn btn-secondary ms-2">Vissza a listához</a>
            </div>
        </div>
    </div>
</div>