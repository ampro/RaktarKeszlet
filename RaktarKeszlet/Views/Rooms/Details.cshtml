@model RaktarKeszlet.ViewModels.RoomDetailsViewModel
@{
    ViewData["Title"] = "Helyiség részletei";
}

<h1>@Model.Room.Name adatai</h1>
<p class="text-muted">Épület: <strong>@(Model.Room.Building?.Name ?? "-")</strong></p>
<hr />

<!-- AGGREGÁTUMOK AZ OLDAL TETEJEÉN (Kártyák) -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Nyilvántartott polcok</h6>
                <h2 class="mb-0"><i class="bi bi-bookshelf"></i> @Model.TotalShelvesCount db</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-info text-dark shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-dark-50">Helyiség Készlete</h6>
                <h2 class="mb-0">@Model.TotalProductsCount db termék</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Készlet Értéke</h6>
                <h2 class="mb-0">@Model.TotalProductsValue.ToString("N0") Ft</h2>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3 text-secondary"><i class="bi bi-door-open"></i> A helyiséghez tartozó polcok/sorok</h4>

<!-- RÉSZNÉZET BEHÍVÁSA: Polcok táblázata -->
<partial name="_ShelfListTable" model="Model.PagedShelves" />

<!-- RÉSZNÉZET BEHÍVÁSA: Lapozó -->
<partial name="_Pagination" model="(Model.CurrentPage, Model.TotalPages)" />
<div class="mt-4 border-top pt-4">
  
    
    <!-- EZ AZ ÚJ GOMB -->
    <a asp-controller="Products" asp-action="Create"
       asp-route-roomId="@Model.Room.Id"
       asp-route-buildingId="@Model.Room.BuildingId"
       asp-route-companyId="@Model.Room.Building?.CompanyId"
       class="btn btn-success shadow-sm me-2">
        <i class="bi bi-plus-circle"></i> Új termék elhelyezése ebben a helyiségben
    </a>

    <a asp-action="Index" class="btn btn-outline-secondary">Vissza a listához</a>
    <a asp-controller="Buildings" asp-action="Details" asp-route-id="@Model.Room.BuildingId" class="btn btn-outline-primary ms-2">Vissza az épülethez</a>
</div>
