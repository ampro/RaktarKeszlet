@model IEnumerable<RaktarKeszlet.Models.Room>

@{
    ViewData["Title"] = "Raktárhelyiségek";
}

<h1>Raktárhelyiségek</h1>
<p>
    <a asp-action="Create" class="btn btn-success">Új helyiség felvitele</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Épület</th>
                <th>Helyiség neve</th>
                <th>Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Building != null ? item.Building.Name : "-")</td>
                    <td class="fw-bold">@item.Name</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                        <!-- ÚJ GOMB: Részletek (Details) -->
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>