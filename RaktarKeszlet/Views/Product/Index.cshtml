@model RaktarKeszlet.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Termťkek listŠja";
}

<h1>Termťkek listŠja</h1>

<!-- Keresű ťs szŻrű szekciů -->
<form asp-controller="Products" asp-action="Index" method="get" class="mb-4 bg-light p-3 rounded">
    <div class="row align-items-end">
        <!-- Szabad szavas keresű -->
        <div class="col-md-4 mb-3 mb-md-0">
            <label class="form-label">Keresťs</label>
            <input type="text" asp-for="SearchTerm" name="searchTerm" class="form-control" placeholder="Nťv vagy vonalkůd alapjŠn..." />
        </div>
        <!-- Kategůria szŻrű -->
        <div class="col-md-4 mb-3 mb-md-0">
            <label class="form-label">Kategůria</label>
            <select asp-for="SelectedCategoryId" name="selectedCategoryId" asp-items="Model.Categories" class="form-control">
                <option value="">-- ÷sszes kategůria --</option>
            </select>
        </div>
        <!-- Gombok -->
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100 mb-2">Keresťs / SzŻrťs</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">SzŻrűk tŲrlťse</a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">ŕj termťk felvitele</a>
</p>

<!-- ReszponzŪv tŠblŠzat -->
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Kategůria</th>
                <th>Megnevezťs</th>
                <th>Ńr</th>
                <th>MŻveletek</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <!-- A listaelemek kattinthatůk a mŻvelet gombokon keresztŁl -->
                <tr>
                    <td>@(item.Category != null ? item.Category.Name : "Nincs besorolva")</td>
                    <td class="fw-bold">@item.Name</td>
                    <td>@item.Price Ft</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztťs</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Rťszletek</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">TŲrlťs</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- LapozŠs (Pťlda a hosszķ listŠkhoz) -->
@if (Model.Products.Any())
{
    <div class="mt-4 d-flex justify-content-center">
        <!-- Itt adjuk Št a jelenlegi keresűszůt ťs kategůriŠt a lapozŠsnŠl is, hogy ne vesszen el a szŻrťs -->
        <a asp-action="Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-selectedCategoryId="@Model.SelectedCategoryId" asp-route-page="1" class="btn btn-outline-primary mx-1">1. oldal</a>
        <a asp-action="Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-selectedCategoryId="@Model.SelectedCategoryId" asp-route-page="2" class="btn btn-outline-primary mx-1">2. oldal</a>
    </div>
}