@model RaktarKeszlet.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Termékek listája";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Összes termék listája</h1>
        <p class="text-muted">A raktárban fellelhető összes termék áttekintése és keresése.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Új termék felvitele
        </a>
    </div>
</div>

<!-- SZŰRŐ ÉS KERESŐ SÁV -->
<form method="get" asp-action="Index" class="bg-light p-3 rounded shadow-sm mb-4 border">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-bold">Keresés (Név, Vonalkód)</label>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Szabad szavas kereső..." />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">Kategória</label>
            <select name="selectedCategoryId" class="form-select" asp-items="Model.Categories">
                <option value="">Mindegyik</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">Épület</label>
            <select name="selectedBuildingId" class="form-select" asp-items="Model.Buildings">
                <option value="">Bárhol</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">Doboz/Raklap</label>
            <select name="selectedContainerId" class="form-select" asp-items="Model.Containers">
                <option value="">Bármiben</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Szűrés</button>
        </div>
    </div>
</form>

<!-- TÁBLÁZAT (Változatlan a korábbiakhoz képest) -->
<div class="table-responsive shadow-sm rounded mb-4">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Fotó</th>
                <th>Kategória</th>
                <th>Megnevezés</th>
                <th>Ár</th>
                <th class="text-end">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Products.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Nincs a keresésnek megfelelő termék.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.PhotoUrl))
                            {
                                <img src="@item.PhotoUrl" alt="@item.Name" class="img-thumbnail" style="width: 64px; height: 64px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width: 64px; height: 64px;">
                                    <i class="bi bi-image text-white-50 fs-3"></i>
                                </div>
                            }
                        </td>
                        <td>
                            @(item.Category != null ? Html.Raw($"<span class='badge bg-info text-dark fs-6'>{item.Category.Name}</span>") : Html.Raw("<span class='text-muted'>Nincs besorolva</span>"))
                        </td>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td class="fs-5">@item.Price.ToString("N0") Ft</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- LAPOZÁS (Pagination) -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Termék lapozás">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&searchTerm=@Model.SearchTerm&selectedCategoryId=@Model.SelectedCategoryId&selectedBuildingId=@Model.SelectedBuildingId&selectedContainerId=@Model.SelectedContainerId">@i</a>
                </li>
            }
        </ul>
    </nav>
}