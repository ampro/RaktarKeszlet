@model RaktarKeszlet.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Termékek listája";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Összes termék listája</h1>
        <p class="text-muted">A raktárban fellelhető összes termék áttekintése és keresése.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Új termék felvitele
        </a>
    </div>
</div>

<!-- SZŰRŐ ÉS KERESŐ SÁV -->
<form method="get" asp-action="Index" class="bg-light p-3 rounded shadow-sm mb-4 border">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label fw-bold small">Keresés</label>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Név, vonalkód..." />
        </div>

        <!-- CÉG SZŰRŐ (Ez irányítja a többit) -->
        <div class="col-md-2">
            <label class="form-label fw-bold small">Cég</label>
            <select name="selectedCompanyId" id="searchCompany" class="form-select form-select-sm">
                <option value="">Mindegyik</option>
                @foreach (var c in Model.Companies)
                {
                    if (Model.SelectedCompanyId == c.Id)
                    {
                        <option value="@c.Id" selected>@c.Name</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                }
            </select>
        </div>

        <!-- ÉPÜLET SZŰRŐ (A data-company tartalmazza, hogy hova tartozik) -->
        <div class="col-md-2">
            <label class="form-label fw-bold small">Épület</label>
            <select name="selectedBuildingId" id="searchBuilding" class="form-select form-select-sm">
                <option value="">Bárhol</option>
                @foreach (var b in Model.Buildings)
                {
                    if (Model.SelectedBuildingId == b.Id)
                    {
                        <option value="@b.Id" data-company="@b.CompanyId" selected>@b.Name</option>
                    }
                    else
                    {
                        <option value="@b.Id" data-company="@b.CompanyId">@b.Name</option>
                    }
                }
            </select>
        </div>

        <!-- TÁROLÓ SZŰRŐ -->
        <div class="col-md-2">
            <label class="form-label fw-bold small">Doboz/Raklap</label>
            <select name="selectedContainerId" id="searchContainer" class="form-select form-select-sm">
                <option value="">Bármiben</option>
                @foreach (var c in Model.Containers)
                {
                    if (Model.SelectedContainerId == c.Id)
                    {
                        <option value="@c.Id" data-company="@c.CompanyId" selected>@c.Name (@c.Type)</option>
                    }
                    else
                    {
                        <option value="@c.Id" data-company="@c.CompanyId">@c.Name (@c.Type)</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label fw-bold small">Kategória</label>
            <select name="selectedCategoryId" class="form-select form-select-sm" asp-items="Model.Categories">
                <option value="">Mindegyik</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i> Szűrés</button>
        </div>
    </div>
</form>

<!-- TÁBLÁZAT (Változatlan a korábbiakhoz képest) -->
<div class="table-responsive shadow-sm rounded mb-4">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Fotó</th>
                <th>Kategória</th>
                <th>Megnevezés</th>
                <th>Ár</th>
                <th class="text-end">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Products.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Nincs a keresésnek megfelelő termék.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.PhotoUrl))
                            {
                                <img src="@item.PhotoUrl" alt="@item.Name" class="img-thumbnail" style="width: 64px; height: 64px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width: 64px; height: 64px;">
                                    <i class="bi bi-image text-white-50 fs-3"></i>
                                </div>
                            }
                        </td>
                        <td>
                            @(item.Category != null ? Html.Raw($"<span class='badge bg-info text-dark fs-6'>{item.Category.Name}</span>") : Html.Raw("<span class='text-muted'>Nincs besorolva</span>"))
                        </td>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td class="fs-5">@item.Price.ToString("N0") Ft</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- LAPOZÁS (Pagination) -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Termék lapozás">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&searchTerm=@Model.SearchTerm&selectedCategoryId=@Model.SelectedCategoryId&selectedBuildingId=@Model.SelectedBuildingId&selectedContainerId=@Model.SelectedContainerId">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function applyFilterCascade() {
            var selectedCompany = document.getElementById('searchCompany').value;
            var buildingSelect = document.getElementById('searchBuilding');
            var containerSelect = document.getElementById('searchContainer');

            // 1. Épületek szűrése a Cég alapján
            Array.from(buildingSelect.options).forEach(function(opt) {
                if (opt.value === "" || selectedCompany === "") {
                    opt.style.display = ""; // Ha nincs cég választva, mindegyik épületet mutatjuk
                } else if (opt.getAttribute("data-company") === selectedCompany) {
                    opt.style.display = ""; // Ha megegyezik a cég azonosítója
                } else {
                    opt.style.display = "none"; // Elrejtés
                    // Ha véletlenül egy elrejtett elem volt már kiválasztva, nullázzuk
                    if (buildingSelect.value === opt.value) {
                        buildingSelect.value = "";
                    }
                }
            });

            // 2. Tárolók szűrése a Cég alapján
            Array.from(containerSelect.options).forEach(function(opt) {
                if (opt.value === "" || selectedCompany === "") {
                    opt.style.display = "";
                } else if (opt.getAttribute("data-company") === selectedCompany) {
                    opt.style.display = "";
                } else {
                    opt.style.display = "none";
                    if (containerSelect.value === opt.value) {
                        containerSelect.value = "";
                    }
                }
            });
        }

        // Amikor a felhasználó céget vált, fusson le a szűrés:
        document.getElementById('searchCompany').addEventListener('change', applyFilterCascade);

        // Az oldal betöltésekor is fusson le, hogy ha például már volt kiválasztott Cég a URL-ben,
        // a többi menü kapásból szűrve töltődjön be!
        window.addEventListener('load', applyFilterCascade);
    </script>
}