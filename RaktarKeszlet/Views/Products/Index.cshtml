@{
}
@model RaktarKeszlet.ViewModels.ProductListViewModel

@{
    ViewData["Title"] = "Termékek listája";
}

<h1>Termékek listája</h1>

<!-- Kereső és szűrő szekció -->
<form asp-controller="Products" asp-action="Index" method="get" class="mb-4 bg-light p-3 rounded">
    <div class="row align-items-end">
        <!-- Szabad szavas kereső -->
        <div class="col-md-4 mb-3 mb-md-0">
            <label class="form-label">Keresés</label>
            <input type="text" asp-for="SearchTerm" name="searchTerm" class="form-control" placeholder="Név vagy vonalkód alapján..." />
        </div>
        <!-- Kategória szűrő -->
        <div class="col-md-4 mb-3 mb-md-0">
            <label class="form-label">Kategória</label>
            <select asp-for="SelectedCategoryId" name="selectedCategoryId" asp-items="Model.Categories" class="form-control">
                <option value="">-- Összes kategória --</option>
            </select>
        </div>
        <!-- Gombok -->
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100 mb-2">Keresés / Szűrés</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Szűrők törlése</a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Új termék felvitele</a>
</p>

<!-- Reszponzív táblázat -->
<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Kategória</th>
                <th>Megnevezés</th>
                <th>Ár</th>
                <th>Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <!-- A listaelemek kattinthatók a művelet gombokon keresztül -->
                <tr>
                    <td>@(item.Category != null ? item.Category.Name : "Nincs besorolva")</td>
                    <td class="fw-bold">@item.Name</td>
                    <td>@item.Price Ft</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Lapozás (Példa a hosszú listákhoz) -->
@if (Model.Products.Any())
{
    <div class="mt-4 d-flex justify-content-center">
        <!-- Itt adjuk át a jelenlegi keresőszót és kategóriát a lapozásnál is, hogy ne vesszen el a szűrés -->
        <a asp-action="Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-selectedCategoryId="@Model.SelectedCategoryId" asp-route-page="1" class="btn btn-outline-primary mx-1">1. oldal</a>
        <a asp-action="Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-selectedCategoryId="@Model.SelectedCategoryId" asp-route-page="2" class="btn btn-outline-primary mx-1">2. oldal</a>
    </div>
}