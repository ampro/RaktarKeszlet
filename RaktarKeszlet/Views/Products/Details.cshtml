@model RaktarKeszlet.Models.Product

@{
    ViewData["Title"] = "Termék részletei";
}

<h1>Termék részletei</h1>
<p class="text-muted">Minden információ és tárolási adat a kiválasztott termékről.</p>
<hr />

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-tag-fill"></i> @Model.Name</h5>
                <!-- Ár a fejlécben is kiemelve -->
                <span class="badge bg-success fs-5">@Model.Price.ToString("N0") Ft</span>
            </div>

            <div class="card-body bg-light row">
                <!-- BAL OSZLOP: Kép és Alapadatok -->
                <div class="col-md-6 border-end">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                        {
                            <img src="@Model.PhotoUrl" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 250px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded shadow-sm mx-auto" style="width: 200px; height: 200px;">
                                <i class="bi bi-image text-white-50" style="font-size: 5rem;"></i>
                            </div>
                            <p class="text-muted mt-2 small">Nincs fotó feltöltve</p>
                        }
                    </div>

                    <dl class="row mb-0">
                        <!-- ÚJ: Az ár kiemelten a termék adatai között -->
                        <dt class="col-sm-5 text-muted">Ár</dt>
                        <dd class="col-sm-7 fw-bold text-success fs-5">@Model.Price.ToString("N0") Ft</dd>

                        <dt class="col-sm-5 text-muted">Kategória</dt>
                        <dd class="col-sm-7 fw-bold">@(Model.Category?.Name ?? "Nincs besorolva")</dd>

                        <dt class="col-sm-5 text-muted">Vonalkód</dt>
                        <dd class="col-sm-7">@(Model.Barcode ?? "-")</dd>

                        <dt class="col-sm-5 text-muted">QR Kód (R)</dt>
                        <dd class="col-sm-7">@(Model.RCode ?? "-")</dd>
                    </dl>
                </div>

                <!-- JOBB OSZLOP: Tárolási hierarchia -->
                <div class="col-md-6 ps-4">
                    <h6 class="text-primary fw-bold border-bottom pb-2 mb-3"><i class="bi bi-geo-alt"></i> Tárolási hely</h6>
                    <dl class="row mb-0">

                        <dt class="col-sm-5 text-muted">Cég / Tulaj.</dt>
                        <dd class="col-sm-7 fw-bold">
                            @if (Model.Company != null)
                            {
                                <a asp-controller="Companies" asp-action="Details" asp-route-id="@Model.CompanyId" class="text-decoration-none text-primary">
                                    <i class="bi bi-link-45deg"></i> @Model.Company.Name
                                </a>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </dd>

                        <dt class="col-sm-5 text-muted">Épület</dt>
                        <dd class="col-sm-7">
                            @if (Model.Building != null)
                            {
                                <a asp-controller="Buildings" asp-action="Details" asp-route-id="@Model.BuildingId" class="text-decoration-none text-primary">
                                    <i class="bi bi-link-45deg"></i> @Model.Building.Name
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Nincs megadva</span>
                            }
                        </dd>

                        <dt class="col-sm-5 text-muted">Helyiség</dt>
                        <dd class="col-sm-7">
                            @if (Model.Room != null)
                            {
                                <a asp-controller="Rooms" asp-action="Details" asp-route-id="@Model.RoomId" class="text-decoration-none text-primary">
                                    <i class="bi bi-link-45deg"></i> @Model.Room.Name
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Nincs megadva</span>
                            }
                        </dd>

                        <dt class="col-sm-5 text-muted">Polc/Sor</dt>
                        <dd class="col-sm-7">
                            @if (Model.Shelf != null)
                            {
                                <a asp-controller="Shelves" asp-action="Details" asp-route-id="@Model.ShelfId" class="text-decoration-none text-primary">
                                    <i class="bi bi-link-45deg"></i> @Model.Shelf.Identifier
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Nincs megadva</span>
                            }
                        </dd>

                        <dt class="col-sm-5 text-muted">Tárolóeszköz</dt>
                        <dd class="col-sm-7">
                            @if (Model.StorageContainer != null)
                            {
                                <a asp-controller="StorageContainers" asp-action="Details" asp-route-id="@Model.StorageContainerId" class="text-decoration-none">
                                    <span class="badge bg-info text-dark shadow-sm">
                                        <i class="bi bi-box"></i> @Model.StorageContainer.Name (@Model.StorageContainer.Type)
                                    </span>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Nincs megadva</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card-footer bg-white border-top-0 pt-3 pb-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Szerkesztés</a>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Vissza a listához</a>
            </div>
        </div>
    </div>
</div>