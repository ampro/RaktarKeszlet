@model RaktarKeszlet.ViewModels.ProductEditViewModel
@using RaktarKeszlet.Models

@{
    ViewData["Title"] = "Termék szerkesztése";
}

<h1>Termék adatainak szerkesztése</h1>
<p class="text-muted">A termék adatait és a tárolási helyét itt tudod módosítani.</p>
<hr />

<form asp-action="Edit" enctype="multipart/form-data" class="bg-light p-4 rounded shadow-sm border">
    <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

    <!-- REJTETT MEZŐK: ID és Régi kép útvonal -->
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExistingPhotoUrl" />

    <div class="row">
        <!-- BAL OSZLOP: Alapadatok -->
        <div class="col-md-6 border-end">
            <h5 class="mb-3 text-primary"><i class="bi bi-tag"></i> 1. Termék alapadatok</h5>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Termék neve *</label>
                <input asp-for="Name" class="form-control form-control-lg" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-bold">Ár (Ft) *</label>
                <input asp-for="Price" class="form-control" type="number" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Barcode" class="form-label text-muted">Vonalkód</label>
                    <input asp-for="Barcode" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="RCode" class="form-label text-muted">QR Kód (R kód)</label>
                    <input asp-for="RCode" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-bold">Kategória</label>
                <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                    <option value="">-- Válassz kategóriát! --</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Fénykép módosítása</label>
                <div class="d-flex align-items-center mb-2">
                    @if (!string.IsNullOrEmpty(Model.ExistingPhotoUrl))
                    {
                        <img src="@Model.ExistingPhotoUrl" class="img-thumbnail me-3" style="width: 80px; height: 80px; object-fit: cover;" alt="Jelenlegi kép" />
                        <span class="text-muted small">Jelenlegi kép.<br />Ha nem töltesz fel újat, ez marad.</span>
                    }
                    else
                    {
                        <span class="text-muted small">Ennél a terméknél nincs kép.</span>
                    }
                </div>
                <input asp-for="Photo" type="file" class="form-control" accept="image/*" />
            </div>
        </div>

        <!-- JOBB OSZLOP: Tárolási hierarchia -->
        <div class="col-md-6 ps-4">
            <h5 class="mb-3 text-primary"><i class="bi bi-geo-alt"></i> 2. Tárolás helye</h5>

            <div class="mb-3">
                <label asp-for="CompanyId" class="form-label fw-bold">Cég / Tulajdonos *</label>
                <select asp-for="CompanyId" class="form-select border-primary" asp-items="ViewBag.CompanyId" id="selCompany">
                    <option value="">-- Válassz céget! --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Épület</label>
                <select asp-for="BuildingId" id="selBuilding" class="form-select">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var b in ViewBag.Buildings as List<Building> ?? new List<Building>())
                    {
                        <option value="@b.Id" data-parent="@b.CompanyId">@b.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Helyiség</label>
                <select asp-for="RoomId" id="selRoom" class="form-select">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var r in ViewBag.Rooms as List<Room> ?? new List<Room>())
                    {
                        <option value="@r.Id" data-parent="@r.BuildingId">@r.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Polc/Sor</label>
                <select asp-for="ShelfId" id="selShelf" class="form-select">
                    <option value="">-- Nem adom meg --</option>
                    <!-- Használd a s.Name-t, ha Identifier helyett nálad az fut a polcoknál -->
                    @foreach (var s in ViewBag.Shelves as List<Shelf> ?? new List<Shelf>())
                    {
                        <option value="@s.Id" data-parent="@s.RoomId">@s.Identifier</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="StorageContainerId" class="form-label fw-bold">Tárolóeszköz (Doboz/Raklap)</label>
                <select asp-for="StorageContainerId" id="selContainer" class="form-select border-info">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var c in ViewBag.Containers as List<StorageContainer> ?? new List<StorageContainer>())
                    {
                        <option value="@c.Id" data-parent="@c.ShelfId">@c.Name (@c.Type)</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="mt-4 border-top pt-4 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Mégse, vissza</a>
        <button type="submit" class="btn btn-warning btn-lg ms-2"><i class="bi bi-save"></i> Változtatások mentése</button>
    </div>
</form>

@section Scripts {
    <script>
        // Szerkesztéshez optimalizált, óvatos szűrő script, ami nem törli a meglévő választásokat betöltéskor
        function applyFilter(sourceId, targetId) {
            var sourceVal = document.getElementById(sourceId).value;
            var targetSelect = document.getElementById(targetId);

            Array.from(targetSelect.options).forEach(function(opt) {
                if (opt.value === "") {
                    opt.style.display = "";
                } else if (opt.getAttribute("data-parent") === sourceVal && sourceVal !== "") {
                    opt.style.display = "";
                } else {
                    opt.style.display = "none";
                }
            });
        }

        // Felhasználói kattintás esetén (Ilyenkor direkt nullázzuk a lánc alatti elemeket)
        document.getElementById('selCompany').addEventListener('change', function() {
            document.getElementById('selBuilding').value = "";
            applyFilter('selCompany', 'selBuilding');
            document.getElementById('selBuilding').dispatchEvent(new Event('change'));
        });
        document.getElementById('selBuilding').addEventListener('change', function() {
            document.getElementById('selRoom').value = "";
            applyFilter('selBuilding', 'selRoom');
            document.getElementById('selRoom').dispatchEvent(new Event('change'));
        });
        document.getElementById('selRoom').addEventListener('change', function() {
            document.getElementById('selShelf').value = "";
            applyFilter('selRoom', 'selShelf');
            document.getElementById('selShelf').dispatchEvent(new Event('change'));
        });
        document.getElementById('selShelf').addEventListener('change', function() {
            document.getElementById('selContainer').value = "";
            applyFilter('selShelf', 'selContainer');
        });

        // Az oldal kezdeti betöltésekor végrehajtjuk a szűréseket, de a value (érték) törlése nélkül!
        window.addEventListener('load', function() {
            applyFilter('selCompany', 'selBuilding');
            applyFilter('selBuilding', 'selRoom');
            applyFilter('selRoom', 'selShelf');
            applyFilter('selShelf', 'selContainer');
        });
    </script>
}