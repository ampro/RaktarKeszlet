@model RaktarKeszlet.ViewModels.ProductCreateViewModel
@using RaktarKeszlet.Models

@{
    ViewData["Title"] = "Új termék rögzítése";
}

<h1>Új termék felvitele</h1>
<p class="text-muted">A termék rögzítésekor meg tudod határozni a termék pontos tárolási helyét.</p>
<hr />

<!-- enctype KÖTELEZŐ a fájlfeltöltéshez! -->
<form asp-action="Create" enctype="multipart/form-data" class="bg-light p-4 rounded shadow-sm border">
    <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

    <div class="row">
        <!-- BAL OSZLOP: ALAPADATOK -->
        <div class="col-md-6 border-end">
            <h5 class="mb-3 text-primary"><i class="bi bi-tag"></i> 1. Termék alapadatok</h5>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Termék neve *</label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="Pl. Fúrógép, Harry Potter könyv" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-bold">Ár (Ft) *</label>
                <input asp-for="Price" class="form-control" type="number" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Barcode" class="form-label text-muted">Vonalkód</label>
                    <input asp-for="Barcode" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="RCode" class="form-label text-muted">QR Kód (R kód)</label>
                    <input asp-for="RCode" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-bold">Kategória</label>
                <select asp-for="CategoryId" id="selCategory" class="form-select border-info" onchange="toggleNew('selCategory', 'NewCategoryName')">
                    <option value="">-- Válassz kategóriát --</option>
                    @if (Model.Categories != null)
                    {
                        foreach (var item in Model.Categories)
                        {
                            if (Model.CategoryId.ToString() == item.Value)
                            {
                                <option value="@item.Value" selected>@item.Text</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    }
                    <option value="-1" class="text-success fw-bold">➕ Új kategória rögzítése...</option>
                </select>
                <!-- Ez a rejtett mező jelenik meg, ha az "Új kategória" opciót választják -->
                <input asp-for="NewCategoryName" id="NewCategoryName" class="form-control mt-2 d-none border-success" placeholder="Pl. könyv, szerszám, alkatrész..." />
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Photo" class="form-label fw-bold">Fénykép feltöltése</label>
                <input asp-for="Photo" type="file" class="form-control" accept="image/*" />
                <div class="form-text text-muted">Tölts fel egy fotót (jpg, png). Opcionális.</div>
            </div>
        </div>
       
        <!-- JOBB OSZLOP: Tárolási hierarchia -->
        <div class="col-md-6 ps-4">
            <h5 class="mb-3 text-primary"><i class="bi bi-geo-alt"></i> 2. Tárolás helye</h5>
            <div class="alert alert-warning py-2 mb-4">
                <small>Bármelyik szinten létrehozhatsz új elemet a legördülő lista alján lévő opcióval!</small>
            </div>

            <!-- CÉG -->
            <div class="mb-3">
                <label asp-for="CompanyId" class="form-label fw-bold">Cég / Tulajdonos</label>
                <select asp-for="CompanyId" id="selCompany" class="form-select border-info">
                    <option value="">-- Válassz céget --</option>
                    @foreach (var c in ViewBag.Companies as List<RaktarKeszlet.Models.Company> ?? new List<RaktarKeszlet.Models.Company>())
                    {
                        if (Model.CompanyId == c.Id)
                        {
                            <option value="@c.Id" selected>@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <!-- ÉPÜLET -->
            <div class="mb-3">
                <label class="form-label text-muted">Épület</label>
                <select asp-for="BuildingId" id="selBuilding" class="form-select" onchange="toggleNew('selBuilding', 'NewBuildingName')">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var b in ViewBag.Buildings as List<Building> ?? new List<Building>())
                    {
                        <option value="@b.Id" data-parent="@b.CompanyId">@b.Name</option>
                    }
                    <option value="-1" class="text-success fw-bold">➕ Új épület rögzítése...</option>
                </select>
                <input asp-for="NewBuildingName" id="NewBuildingName" class="form-control mt-2 d-none border-success" placeholder="Írd be az új épület nevét..." />
            </div>

            <!-- HELYISÉG -->
            <div class="mb-3">
                <label class="form-label text-muted">Helyiség</label>
                <select asp-for="RoomId" id="selRoom" class="form-select" onchange="toggleNew('selRoom', 'NewRoomName')">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var r in ViewBag.Rooms as List<Room> ?? new List<Room>())
                    {
                        <option value="@r.Id" data-parent="@r.BuildingId">@r.Name</option>
                    }
                    <option value="-1" class="text-success fw-bold">➕ Új helyiség rögzítése...</option>
                </select>
                <input asp-for="NewRoomName" id="NewRoomName" class="form-control mt-2 d-none border-success" placeholder="Írd be az új helyiség nevét..." />
            </div>

            <!-- POLC/SOR -->
            <div class="mb-3">
                <label class="form-label text-muted">Polc/Sor</label>
                <select asp-for="ShelfId" id="selShelf" class="form-select" onchange="toggleNew('selShelf', 'NewShelfIdentifier')">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var s in ViewBag.Shelves as List<Shelf> ?? new List<Shelf>())
                    {
                        <option value="@s.Id" data-parent="@s.RoomId">@s.Identifier</option>
                    }
                    <option value="-1" class="text-success fw-bold">➕ Új polc rögzítése...</option>
                </select>
                <input asp-for="NewShelfIdentifier" id="NewShelfIdentifier" class="form-control mt-2 d-none border-success" placeholder="Pl. A-sor, 1-es polc..." />
            </div>

            <!-- TÁROLÓ -->
            <div class="mb-3">
                <label class="form-label fw-bold">Tárolóeszköz (Doboz/Raklap)</label>
                <select asp-for="StorageContainerId" id="selContainer" class="form-select border-info" onchange="toggleNew('selContainer', 'NewContainerName')">
                    <option value="">-- Nem adom meg --</option>
                    @foreach (var c in ViewBag.Containers as List<StorageContainer> ?? new List<StorageContainer>())
                    {
                        <!-- AZ ÚJÍTÁS ITT VAN: Bekerült a data-company attribútum is! -->
                        <option value="@c.Id" data-parent="@c.ShelfId" data-company="@c.CompanyId">@c.Name (@c.Type)</option>
                    }
                    <option value="-1" class="text-success fw-bold">➕ Új tároló rögzítése...</option>
                </select>
                <input asp-for="NewContainerName" id="NewContainerName" class="form-control mt-2 d-none border-success" placeholder="Új doboz vagy raklap neve..." />
            </div>
        </div>
        </div>
    <div class="mt-4 border-top pt-4 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Mégse, vissza</a>
        <button type="submit" class="btn btn-success btn-lg ms-2"><i class="bi bi-save"></i> Termék mentése</button>
    </div>
</form>
@section Scripts {
    <script>
        function toggleNew(selectId, inputId) {
            var select = document.getElementById(selectId);
            var input = document.getElementById(inputId);
            if (select && select.value === "-1") {
                input.classList.remove('d-none');
                input.required = true;
            } else if (input) {
                input.classList.add('d-none');
                input.required = false;
                input.value = "";
            }
        }

        var originalOptions = {};

        // A mély-szűrő algoritmus
        function applyDeepFilter() {
            var compVal = document.getElementById('selCompany').value;
            var bldgVal = document.getElementById('selBuilding').value;
            var roomVal = document.getElementById('selRoom').value;
            var shelfVal = document.getElementById('selShelf').value;

            // Belső függvény egy adott szint szűrésére
            function filterLevel(targetId, validParentIds, parentVal, checkCompany = false) {
                var targetSelect = document.getElementById(targetId);
                if (!targetSelect) return null;

                var prevValue = targetSelect.value;
                targetSelect.innerHTML = "";
                var nextValidIds = [];

                originalOptions[targetId].forEach(function(opt) {
                    var parentId = opt.getAttribute("data-parent") || "";
                    var companyId = opt.getAttribute("data-company") || "";

                    var isValid = false;
                    if (opt.value === "" || opt.value === "-1") {
                        isValid = true; // Üres és "Új" opció mindig látszik
                    } else if (parentVal !== "" && parentVal !== "-1") {
                        isValid = (parentId === parentVal); // Ha a közvetlen szülő ki van választva
                    } else if (validParentIds !== null) {
                        isValid = validParentIds.includes(parentId); // Ha nincs kiválasztva, de a felette lévő szintek szűrve vannak

                        // Extrém eset: Tároló, ami nincs konkrét polcon, de a kiválasztott cég udvarán van
                        if (!isValid && checkCompany && compVal !== "" && compVal !== "-1") {
                            if (companyId === compVal && parentId === "") isValid = true;
                        }
                    } else {
                        isValid = true; // Semmi sincs szűrve (a legfelső szint is üres)
                    }

                    // Visszaépítjük a memóriából a DOM-ba
                    if (isValid) {
                        targetSelect.appendChild(opt.cloneNode(true));
                        if (opt.value !== "" && opt.value !== "-1") {
                            nextValidIds.push(opt.value);
                        }
                    }
                });

                // Visszaállítjuk a korábbi kiválasztást, ha a szűrés után is elérhető maradt
                var stillExists = Array.from(targetSelect.options).some(o => o.value === prevValue);
                targetSelect.value = stillExists ? prevValue : "";
                toggleNew(targetId, 'New' + targetId.replace('sel', '') + 'Name');

                // Továbbadjuk az érvényes ID-kat a következő szintnek
                if (parentVal !== "" && parentVal !== "-1") {
                    return nextValidIds;
                } else if (validParentIds === null) {
                    return null;
                } else {
                    return nextValidIds;
                }
            }

            // --- A LÁNCFOLYAMAT (Fentről lefelé) ---
            // 1. Épületek szűrése a Cég alapján
            var validBldgs = filterLevel('selBuilding', null, compVal);

            // 2. Helyiségek szűrése az Épületek alapján
            var validRooms = filterLevel('selRoom', validBldgs, bldgVal);

            // 3. Polcok szűrése a Helyiségek alapján
            var validShelves = filterLevel('selShelf', validRooms, roomVal);

            // 4. Dobozok szűrése a Polcok (és a Cég) alapján
            filterLevel('selContainer', validShelves, shelfVal, true);
        }

        // Az oldal betöltésekor végrehajtandó műveletek
        window.addEventListener('load', function() {
            // Memóriába másoljuk az összes eredeti elemet
            ['selBuilding', 'selRoom', 'selShelf', 'selContainer'].forEach(function(id) {
                var sel = document.getElementById(id);
                if (sel) originalOptions[id] = Array.from(sel.options).map(opt => opt.cloneNode(true));
            });

            // Eseménykezelők bekötése MINDEN legördülőre
            document.getElementById('selCompany').addEventListener('change', applyDeepFilter);
            document.getElementById('selBuilding').addEventListener('change', applyDeepFilter);
            document.getElementById('selRoom').addEventListener('change', applyDeepFilter);
            document.getElementById('selShelf').addEventListener('change', applyDeepFilter);

            // Kezdeti szűrés lefuttatása, hogy rögtön tiszta legyen a felület
            applyDeepFilter();
        });
    </script>
}
