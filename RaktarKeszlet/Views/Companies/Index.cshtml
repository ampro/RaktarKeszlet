@model IEnumerable<RaktarKeszlet.Models.Company>

@{
    ViewData["Title"] = "Saját cégeim";
}

<h1>Saját cégeim és raktáraim</h1>
<p class="text-muted">Itt kezelheted a hozzád tartozó cégeket és a hierarchia csúcsszintjét.</p>

<p>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Új cég felvitele
    </a>
</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Cég / Tulajdonos neve</th>
                <th class="text-end">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">Még nem rögzítettél egyetlen céget sem.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>