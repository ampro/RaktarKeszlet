@model IEnumerable<RaktarKeszlet.Models.Company>

@{
    ViewData["Title"] = "Cégek listája";
}

<h1>Cégek listája</h1>
<p class="text-muted">Itt kezelheted a cégeidet és áttekintheted a hozzájuk közvetlenül rendelt készleteket kategóriánként.</p>

<p>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Új cég felvitele
    </a>
</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th style="width: 30%;">Cég / Tulajdonos neve</th>
                <th style="width: 50%;">Kategóriánkénti készlet (Darab és Érték)</th>
                <th class="text-end" style="width: 20%;">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="3" class="text-center text-muted py-4">Még nincs cég rögzítve a fiókodhoz.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold fs-5">@item.Name</td>

                        <!-- STATISZTIKA OSZLOP -->
                        <td>
                            @if (item.Products != null && item.Products.Any())
                            {
                                <ul class="list-group list-group-flush bg-transparent">
                                    <!-- Csoportosítjuk a termékeket a Kategória neve alapján -->
                                    @foreach (var group in item.Products.GroupBy(p => p.Category != null ? p.Category.Name : "Nincs besorolva"))
                                    {
                                        <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center border-0 px-0 py-1">
                                            <span>
                                                <i class="bi bi-tag text-info me-2"></i><span class="fw-bold text-secondary">@group.Key</span>
                                            </span>
                                            <span>
                                                <!-- Darabszám -->
                                                <span class="badge bg-secondary rounded-pill me-3" style="width: 60px;">@group.Count() db</span>
                                                <!-- Érték (Összegzés) -->
                                                <span class="text-success fw-bold text-end d-inline-block" style="width: 120px;">@group.Sum(p => p.Price).ToString("N0") Ft</span>
                                            </span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Nincs a céghez közvetlenül rendelve termék.</span>
                            }
                        </td>

                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>