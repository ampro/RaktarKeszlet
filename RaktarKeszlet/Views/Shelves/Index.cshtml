@model IEnumerable<RaktarKeszlet.Models.Shelf>

@{
    ViewData["Title"] = "Polcok és Sorok";
}

<h1>Polcok és Sorok</h1>
<p>
    <a asp-action="Create" class="btn btn-success">Új polc felvitele</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Helyiség</th>
                <th>Polc/Sor azonosítója</th>
                <th>Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Room != null ? item.Room.Name : "Nincs megadva")</td>
                    <td class="fw-bold">@item.Identifier</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>