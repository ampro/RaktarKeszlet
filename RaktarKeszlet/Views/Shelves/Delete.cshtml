@model RaktarKeszlet.Models.Shelf


@{
    ViewData["Title"] = "Polc törlése";
}

<h1 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Törlés jóváhagyása</h1>
<h3>Biztosan törölni szeretnéd ezt a polcot vagy sort?</h3>
<p class="text-muted">A művelet végleges és nem vonható vissza!</p>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Törlendő polc adatai</h5>
            </div>
            <div class="card-body bg-light">
                <dl class="row mb-0">
                    <!-- Itt is az Identifier mezőt használjuk -->
                    <dt class="col-sm-5 text-muted">Azonosító</dt>
                    <dd class="col-sm-7 fw-bold fs-4">@Model.Identifier</dd>

                    <dt class="col-sm-5 text-muted mt-3">Melyik helyiségben található?</dt>
                    <dd class="col-sm-7 mt-3">
                        @(Model.Room != null ? Model.Room.Name : "Nincs helyiséghez rendelve")
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-top-0 pt-3 pb-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Igen, véglegesen törlöm</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Mégse, vissza</a>
                </form>
            </div>
        </div>
    </div>
</div>