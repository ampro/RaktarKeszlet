@model RaktarKeszlet.ViewModels.ShelfDetailsViewModel
@{
    ViewData["Title"] = "Polc / Sor részletei";
}

<h1>@Model.Shelf.Identifier adatai</h1>
<p class="text-muted">
    Helyiség: <strong>@(Model.Shelf.Room?.Name ?? "-")</strong>
    (Épület: @(Model.Shelf.Room?.Building?.Name ?? "-"))
</p>
<hr />

<!-- AGGREGÁTUMOK AZ OLDAL TETEJEÉN -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card bg-primary text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Nyilvántartott tárolók</h6>
                <h2 class="mb-0"><i class="bi bi-boxes"></i> @Model.TotalContainersCount db</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-info text-dark shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-dark-50">Polc Készlete</h6>
                <h2 class="mb-0">@Model.TotalProductsCount db termék</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card bg-success text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Készlet Értéke</h6>
                <h2 class="mb-0">@Model.TotalProductsValue.ToString("N0") Ft</h2>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3 text-secondary"><i class="bi bi-box"></i> A polcon elhelyezett tárolóeszközök</h4>

<!-- RÉSZNÉZET BEHÍVÁSA: Tárolóeszközök táblázata -->
<partial name="_StorageContainerListTable" model="Model.PagedContainers" />

<!-- RÉSZNÉZET BEHÍVÁSA: Lapozó -->
<partial name="_Pagination" model="(Model.CurrentPage, Model.TotalPages)" />

<div class="mt-4 border-top pt-4">
    <!-- EZ AZ ÚJ GOMB -->
    <a asp-controller="Products" asp-action="Create"
       asp-route-shelfId="@Model.Shelf.Id"
       asp-route-roomId="@Model.Shelf.RoomId"
       asp-route-buildingId="@Model.Shelf.Room?.BuildingId"
       asp-route-companyId="@Model.Shelf.Room?.Building?.CompanyId"
       class="btn btn-success shadow-sm me-2">
        <i class="bi bi-plus-circle"></i> Új termék elhelyezése ezen a polcon
    </a>

    <!-- Korábbi vissza gombok... -->
</div>



<div class="mt-4 border-top pt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">Vissza a polcok listájához</a>
    <a asp-controller="Rooms" asp-action="Details" asp-route-id="@Model.Shelf.RoomId" class="btn btn-outline-primary ms-2">Vissza a helyiséghez</a>
</div>