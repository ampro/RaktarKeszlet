@model RaktarKeszlet.Models.StorageContainer

@{
    ViewData["Title"] = "Új tárolóeszköz felvitele";
}

<h1>Új tárolóeszköz felvitele</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" class="bg-light p-4 rounded shadow-sm">
            <!-- Validációs hibajelző -->
            <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

            <div class="mb-3">
                <label asp-for="ShelfId" class="form-label fw-bold">Melyik Polcon/Soron található?</label>
                <!-- A legördülő lista, ami a Controllerből kapja az adatot -->
                <select asp-for="ShelfId" class="form-select" asp-items="ViewBag.ShelfId">
                    <option value="">-- Válassz polcot vagy sort! --</option>
                </select>
                <span asp-validation-for="ShelfId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tárolóeszköz azonosítója (pl. D-12 doboz, EUR-1 raklap)</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Mentés</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Vissza a listához</a>
            </div>
        </form>
    </div>
</div>