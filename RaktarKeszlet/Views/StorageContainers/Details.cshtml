@model RaktarKeszlet.ViewModels.StorageContainerDetailsViewModel
@{
    ViewData["Title"] = "Tároló részletei";
}

<h1>@Model.Container.Name (@Model.Container.Type) részletei</h1>
<hr />

<!-- AGGREGÁTUMOK AZ OLDAL TETEJEÉN (Kártyák) -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Összesített darabszám</h6>
                <h2 class="mb-0">@Model.TotalProductsCount db termék</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Összesített Érték</h6>
                <h2 class="mb-0">@Model.TotalProductsValue.ToString("N0") Ft</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-light border shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-muted">Helyszín</h6>
                <h5 class="mb-0 text-dark">
                    Polc: @(Model.Container.Shelf?.Identifier ?? "Nincs polcon")
                </h5>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3 text-secondary"><i class="bi bi-box-seam"></i> A tárolóban található termékek</h4>

<!-- RÉSZNÉZET BEHÍVÁSA: Termékek táblázata -->
<partial name="_ProductListTable" model="Model.PagedProducts" />

<!-- RÉSZNÉZET BEHÍVÁSA: Lapozó -->
<partial name="_Pagination" model="(Model.CurrentPage, Model.TotalPages)" />

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">Vissza a listához</a>
</div>