@model IEnumerable<RaktarKeszlet.Models.StorageContainer>

@{
    ViewData["Title"] = "Tárolóeszközök";
}

<h1>Tárolóeszközök</h1>
<p class="text-muted">Itt kezelheted a polcokon lévő dobozokat, raklapokat és rekeszeket.</p>

<p>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Új tárolóeszköz felvitele
    </a>
</p>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Eszköz neve / Azonosítója</th>
                <th>Típus</th>
                <th>Melyik Polcon/Soron van?</th>
                <th class="text-end">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">Még nem rögzítettél egyetlen tárolóeszközt sem.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td>
                            <span class="badge bg-secondary fs-6">@item.Type</span>
                        </td>
                        <td>
                            @if (item.Shelf != null)
                            {
                                <!-- Itt az Identifier mezőre hivatkozunk, amit a polcoknál használsz! -->
                                <span class="badge bg-success fs-6">@item.Shelf.Identifier</span>
                            }
                            else
                            {
                                <span class="text-danger">Nincs polchoz rendelve</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Szerkesztés</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Részletek</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Törlés</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>