@model RaktarKeszlet.Models.StorageContainer

@{
    ViewData["Title"] = "Tárolóeszköz törlése";
}

<h1 class="text-danger">Törlés jóváhagyása</h1>
<h3>Biztosan törölni szeretnéd ezt a tárolóeszközt?</h3>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Tárolóeszköz adatai</h5>
            </div>
            <div class="card-body bg-light">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Azonosító (Név)</dt>
                    <dd class="col-sm-7 fw-bold fs-5">@Model.Name</dd>

                    <dt class="col-sm-5 text-muted mt-3">Melyik Polcon/Soron van?</dt>
                    <dd class="col-sm-7 mt-3">
                        <!-- IDE FIGYELJ: Ha nálad nem Name, hanem pl. ShelfNumber, akkor írd át! -->
                        @(Model.Shelf != null ? Model.Shelf.Identifier : "Nincs polchoz rendelve")
                    </dd>
                </dl>
            </div>
            <div class="card-footer bg-white border-top-0 pt-3 pb-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Igen, véglegesen törlöm</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Mégse, vissza a listához</a>
                </form>
            </div>
        </div>
    </div>
</div>