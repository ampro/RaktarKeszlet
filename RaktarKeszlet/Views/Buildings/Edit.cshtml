@model RaktarKeszlet.Models.Building

@{
    ViewData["Title"] = "Épület szerkesztése";
}

<h1>Épület szerkesztése</h1>
<p class="text-muted">Itt módosíthatod a meglévő raktárépület adatait és céges besorolását.</p>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" class="bg-light p-4 rounded shadow-sm border">
            <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

            <!-- REJTETT MEZŐ: Az épület azonosítója a mentéshez -->
            <input type="hidden" asp-for="Id" />

            <h5 class="mb-3 text-primary"><i class="bi bi-building"></i> Épület adatai</h5>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Épület megnevezése *</label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="Pl. Központi Raktár, A-épület..." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="CompanyId" class="form-label fw-bold">Cég / Tulajdonos *</label>
                <select asp-for="CompanyId" class="form-select border-primary" asp-items="ViewBag.CompanyId">
                    <option value="">-- Válassz céget! --</option>
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
                <div class="form-text text-muted">Válaszd ki, hogy ez az épület melyik cégedhez tartozik.</div>
            </div>

            <div class="mt-4 border-top pt-4 text-end">
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Mégse, vissza</a>
                <button type="submit" class="btn btn-warning btn-lg ms-2"><i class="bi bi-save"></i> Változtatások mentése</button>
            </div>
        </form>
    </div>
</div>