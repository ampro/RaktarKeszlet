@model IEnumerable<RaktarKeszlet.Models.Room>

<div class="table-responsive shadow-sm rounded border bg-white mb-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Helyiség megnevezése</th>
                <th class="text-end">Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="2" class="text-center py-3 text-muted">Nincsenek helyiségek rögzítve.</td></tr>
            }
            @foreach (var item in Model)
            {
                <!-- Fúrás a Helyiség szintjére -->
                <tr style="cursor: pointer;" onclick="window.location.href='/Rooms/Details/@item.Id'">
                    <td class="fw-bold text-primary"><i class="bi bi-door-open"></i> @item.Name</td>
                    <td class="text-end">
                        <a asp-controller="Rooms" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Megnyitás</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>